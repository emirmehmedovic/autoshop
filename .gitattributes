# Auto detect text files and perform LF normalization
* text=auto

# Source files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf

# Images
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.svg text eol=lf
*.webp binary

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
